# Copy to .env.local and .env, then fill in local secrets.

# Local Postgres used by Docker Compose and integration tests.
MARKET_PIPE__POSTGRES_HOST=localhost
MARKET_PIPE__POSTGRES_PORT=5432
MARKET_PIPE__POSTGRES_DB=market_pipe
MARKET_PIPE__POSTGRES_USER=market_pipe
MARKET_PIPE__POSTGRES_PASSWORD=market_pipe
MARKET_PIPE__DATABASE_URL=postgres://market_pipe:market_pipe@localhost:5432/market_pipe

# CoinGecko Demo API key for opt-in live smoke runs.
MARKET_PIPE__COINGECKO_API_KEY=
MARKET_PIPE__COINGECKO_RETRY_ATTEMPTS=3
MARKET_PIPE__COINGECKO_RETRY_BASE_MS=1000
MARKET_PIPE__COINGECKO_PAGE_LIMIT=1
MARKET_PIPE__COINGECKO_PER_PAGE=250

# Alpha Vantage API key for daily stock OHLCV ingestion and opt-in live smoke runs.
MARKET_PIPE__ALPHAVANTAGE_API_KEY=
